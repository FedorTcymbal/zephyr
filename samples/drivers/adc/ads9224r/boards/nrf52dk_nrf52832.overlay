/ {
	aliases {
		adc-ads9224r = &ads9224r0;
	};
};

&spi1 {
	status = "okay";

	ads9224r0: ads9224r@0 {
		compatible = "ti,ads9224r";
		reg = <0>;
		spi-max-frequency = <16000000>;
		channels = <4>;
		drdy-gpios = <&gpio0 12 GPIO_ACTIVE_LOW>;
		#io-channel-cells = <1>;
	};
};
